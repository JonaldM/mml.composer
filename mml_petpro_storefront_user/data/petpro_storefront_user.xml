<?xml version="1.0" encoding="utf-8"?>
<!--
    res.users template for the PetPro storefront RPC account.

    INTENTIONALLY: not noupdate=1.
        We want module upgrades to keep this user's group membership in sync
        with whatever the current ACLs declare. If a future upgrade tightens
        permissions, the operator should not have to re-link the user.

    INTENTIONALLY: forcecreate="1".
        On first install of a fresh database, this record must be created.
        On databases where the user already exists at this XML id, the
        record is merely refreshed (group membership re-asserted).

    INTENTIONALLY: NO password field.
        A password set in this XML would (a) leak in source control, (b) be
        the same on every deployment, and (c) be impossible to rotate.
        Instead the operator MUST set a password (and an Odoo 19 API key)
        out-of-band immediately after install. See:
            docs/operations/2026-04-27-petpro-storefront-user-runbook.md

        Until that step is complete this user CANNOT log in. That is by
        design — fail closed.
-->
<odoo>
    <!--
        share=True (portal/external user), NOT an internal base.group_user.
        base.group_user is a FULL internal user: it carries a broad implied-read
        surface (res.users enumeration, most master data, internal-only models)
        that contradicts this module's least-privilege purpose. The storefront's
        actual needs are covered explicitly: the transactional models in
        security/ir.model.access.csv (row-scoped by petpro_storefront_record_rules.xml)
        plus the master-data read ACLs added there (countries, currency, UoM, taxes).
        If a future storefront flow genuinely needs an internal-only model, add a
        narrow explicit ACL for THAT model — do NOT re-add base.group_user.
    -->
    <record id="user_petpro_storefront" model="res.users" forcecreate="1">
        <field name="name">MML PetPro Storefront</field>
        <field name="login">petpro_storefront@petpro.co.nz</field>
        <field name="email">petpro_storefront@petpro.co.nz</field>
        <field name="active">True</field>
        <field name="share">True</field>
        <field name="notification_type">email</field>
        <field name="signature">PetPro Storefront RPC user — system generated. Do not reply.</field>
        <field name="group_ids" eval="[
            (6, 0, [
                ref('mml_petpro_storefront_user.group_petpro_storefront'),
            ])
        ]"/>
    </record>
</odoo>
