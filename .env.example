# Copy this file to .env and fill in values before running deployment scripts.
# Never commit .env to git — it is in .gitignore.

# --- Required ---
MML_SSH_HOST=
MML_SSH_USER=

# --- Authentication (choose ONE path) ---
#
# 1. Preferred: SSH key auth.
#    Either set the explicit path below, or place an Ed25519 key at
#    ~/.ssh/id_ed25519 and ssh_utils will pick it up automatically.
MML_SSH_PRIVATE_KEY_PATH=

# 2. Legacy: password auth. BOTH variables must be set; setting only
#    MML_SSH_PASSWORD is intentionally rejected so password auth never
#    happens by accident. sudo_run() also requires MML_SSH_PASSWORD even
#    when SSH itself uses key auth.
MML_SSH_USE_PASSWORD=
MML_SSH_PASSWORD=

# --- Host-key policy ---
#
# Default behavior: unknown SSH hosts are rejected (RejectPolicy). The host
# fingerprint must already be present in ~/.ssh/known_hosts.
#
# Set MML_SSH_AUTO_ACCEPT_HOST=1 ONLY for first-bootstrap connections to a
# new host. Unset (or remove) it again as soon as the host key is recorded.
MML_SSH_AUTO_ACCEPT_HOST=
